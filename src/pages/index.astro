---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HeroSection from '../components/HeroSection.astro';
import CapabilityStrip from '../components/CapabilityStrip.astro';
import OperatingFunctionsSection from '../components/OperatingFunctionsSection.astro';
import { siteMeta } from '../data/site';
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <SiteHeader />
  <main>
    <HeroSection />
    <CapabilityStrip />
    <OperatingFunctionsSection />
  </main>
</BaseLayout>
